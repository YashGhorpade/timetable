# ─── Database ──────────────────────────────────────────────────────────────────
MSSQL_SA_PASSWORD=TimetableSystem@2024!
DATABASE_URL=mssql+pyodbc://sa:TimetableSystem@2024!@localhost:1433/timetable_db?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-256-bit-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
